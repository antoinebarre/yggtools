# Generated by uvforge {{ uvforge_version }} — do not remove this line.
name: CI

on:
  push:
    branches: ["main", "master"]
  pull_request:
    branches: ["main", "master"]

jobs:
  quality:
    name: Quality pipeline (Python ${{ "{{" }} matrix.python-version {{ "}}" }})
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        python-version: ["{{ python_version }}", "3.13"]

    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v5
        with:
          enable-cache: true

      - name: Set up Python ${{ "{{" }} matrix.python-version {{ "}}" }}
        run: uv python install ${{ "{{" }} matrix.python-version {{ "}}" }}

      - name: Install dependencies
        run: uv sync --python ${{ "{{" }} matrix.python-version {{ "}}" }}

      - name: Run quality pipeline
        run: make ci

      - name: Upload quality report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: quality-report-py${{ "{{" }} matrix.python-version {{ "}}" }}
          path: work/report.md
          if-no-files-found: ignore
