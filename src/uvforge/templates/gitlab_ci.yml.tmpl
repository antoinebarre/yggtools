# Generated by uvforge {{ uvforge_version }} — do not remove this line.
variables:
  UV_CACHE_DIR: "$CI_PROJECT_DIR/.uv-cache"

cache:
  key: "$CI_COMMIT_REF_SLUG"
  paths:
    - .uv-cache/
    - .venv/

stages:
  - quality

.quality_base:
  stage: quality
  before_script:
    - pip install uv --quiet
    - uv sync
  script:
    - make ci
  artifacts:
    when: always
    paths:
      - work/report.md
    expire_in: 30 days

"quality:{{ python_version }}":
  extends: .quality_base
  image: python:{{ python_version }}-slim

"quality:3.13":
  extends: .quality_base
  image: python:3.13-slim
