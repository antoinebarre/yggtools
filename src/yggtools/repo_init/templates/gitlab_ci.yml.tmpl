# Generated by yggtools — do not remove this line.
variables:
  UV_CACHE_DIR: "$CI_PROJECT_DIR/.uv-cache"

cache:
  key: "$CI_COMMIT_REF_SLUG"
  paths:
    - .uv-cache/
    - .venv/

stages:
  - static
  - test
  - audit

.base:
  before_script:
    - pip install uv --quiet
    - uv sync

# ── static ────────────────────────────────────────────────────────────────────

"lint:{{ python_version }}":
  extends: .base
  stage: static
  image: python:{{ python_version }}-slim
  script:
    - uv run yggtools run format --ci
    - uv run yggtools run ruff --ci
    - uv run yggtools run flake8 --ci
  artifacts:
    when: always
    paths:
      - work/ci
    expire_in: 7 days

