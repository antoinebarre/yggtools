# Generated by yggtools — do not remove this line.
variables:
  UV_CACHE_DIR: "$CI_PROJECT_DIR/.uv-cache"

cache:
  key: "$CI_COMMIT_REF_SLUG"
  paths:
    - .uv-cache/
    - .venv/

stages:
  - quality

.base:
  before_script:
    - pip install uv --quiet
    - uv sync

"quality:{{ python_version }}":
  extends: .base
  stage: quality
  image: python:{{ python_version }}-slim
  script:
    - uv run yggtools pipeline
  artifacts:
    when: always
    paths:
      - work/reports/
    expire_in: 7 days

"quality:3.13":
  extends: .base
  stage: quality
  image: python:3.13-slim
  script:
    - uv run yggtools pipeline
  artifacts:
    when: always
    paths:
      - work/reports/
    expire_in: 7 days
